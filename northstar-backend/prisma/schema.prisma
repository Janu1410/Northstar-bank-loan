generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  APPLICATION_SUBMITTED
  PHONE_VERIFICATION_PENDING
  SIGN_LOAN_AGREEMENT
  VERIFICATION_DEPOSIT_RETURN
  FUNDED
  DECLINED
}

enum EmploymentStatus {
  EMPLOYED
  SELF_EMPLOYED
  UNEMPLOYED
  RETIRED
  STUDENT
}

enum AccountType {
  CHECKING
  SAVINGS
}

enum BankAccountAge {
  LESS_THAN_6_MONTHS
  SIX_TO_TWELVE_MONTHS
  MORE_THAN_1_YEAR
}

enum CreditTier {
  EXCELLENT
  GOOD
  FAIR
  POOR
  BAD
  UNKNOWN
}

model Application {
  id                  String            @id @default(uuid())
  applicationId       String            @unique
  amountRequested     Int
  firstName           String
  lastName            String
  dateOfBirth         DateTime
  ssnEncrypted        String
  email               String
  phone               String
  mailingAddress      String
  currentStatus       ApplicationStatus @default(APPLICATION_SUBMITTED)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  employmentDetail    EmploymentDetail?
  bankDetail          BankDetail?
  reference           Reference?
  legalConsent        LegalConsent?
  statusLogs          StatusLog[]
  bankVerification    BankVerification?
}

model EmploymentDetail {
  id                   String             @id @default(uuid())
  applicationIdRef     String             @unique
  employmentStatus     EmploymentStatus
  monthlyGrossIncome   Int
  employerName         String?
  employerPhone        String?
  createdAt            DateTime           @default(now())

  application          Application        @relation(fields: [applicationIdRef], references: [id], onDelete: Cascade)
}

model BankDetail {
  id                    String          @id @default(uuid())
  applicationIdRef      String          @unique
  accountType           AccountType
  routingNumber         String
  accountNumberEncrypted String
  bankAccountAge        BankAccountAge
  creditTier            CreditTier
  createdAt             DateTime        @default(now())

  application           Application     @relation(fields: [applicationIdRef], references: [id], onDelete: Cascade)
}

model Reference {
  id                    String       @id @default(uuid())
  applicationIdRef      String       @unique
  name                  String
  phone                 String
  relationship          String
  createdAt             DateTime     @default(now())

  application           Application  @relation(fields: [applicationIdRef], references: [id], onDelete: Cascade)
}

model LegalConsent {
  id                    String       @id @default(uuid())
  applicationIdRef      String       @unique
  creditAssessment      Boolean
  tcpaConsent           Boolean
  consentIpAddress      String?
  createdAt             DateTime     @default(now())

  application           Application  @relation(fields: [applicationIdRef], references: [id], onDelete: Cascade)
}

model StatusLog {
  id                    String            @id @default(uuid())
  applicationIdRef      String
  status                ApplicationStatus
  note                  String?
  createdAt             DateTime          @default(now())

  application           Application       @relation(fields: [applicationIdRef], references: [id], onDelete: Cascade)
}

enum BankVerificationStatus {
  PENDING
  COMPLETED
  FAILED
}

model BankVerification {
  id               String                 @id @default(uuid())
  applicationIdRef String                 @unique
  provider         String?
  status           BankVerificationStatus @default(PENDING)
  verifiedAt       DateTime?
  createdAt        DateTime               @default(now())

  application      Application            @relation(fields: [applicationIdRef], references: [id], onDelete: Cascade)
}