generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  APPLICATION_SUBMITTED
  PHONE_VERIFICATION_PENDING
  SIGN_LOAN_AGREEMENT
  VERIFICATION_DEPOSIT_RETURN
  FUNDED
  DECLINED
}

enum EmploymentStatus {
  EMPLOYED
  SELF_EMPLOYED
  UNEMPLOYED
  RETIRED
  STUDENT
}

enum AccountType {
  CHECKING
  SAVINGS
}

enum BankAccountAge {
  LESS_THAN_6_MONTHS
  SIX_TO_TWELVE_MONTHS
  MORE_THAN_1_YEAR
}

enum CreditTier {
  EXCELLENT
  GOOD
  FAIR
  POOR
  BAD
  UNKNOWN
}

model Application {
  id                  String            @id @default(uuid())
  applicationId       String            @unique
  amountRequested     Int
  firstName           String
  lastName            String
  dateOfBirth         DateTime
  ssnEncrypted        String
  email               String
  phone               String
  mailingAddress      String
  currentStatus       ApplicationStatus @default(APPLICATION_SUBMITTED)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  employmentDetail    EmploymentDetail?
  bankDetail          BankDetail?
  reference           Reference?
  legalConsent        LegalConsent?
  statusLogs          StatusLog[]
  bankVerification    BankVerification?
  documentRequests    DocumentRequest[]
  notifications       Notification[]
  agreement           ApplicationAgreement?
}

model EmploymentDetail {
  id                   String             @id @default(uuid())
  applicationIdRef     String             @unique
  employmentStatus     EmploymentStatus
  monthlyGrossIncome   Int
  employerName         String?
  employerPhone        String?
  createdAt            DateTime           @default(now())

  application          Application        @relation(fields: [applicationIdRef], references: [id], onDelete: Cascade)
}

model BankDetail {
  id                    String          @id @default(uuid())
  applicationIdRef      String          @unique
  accountType           AccountType
  routingNumber         String
  accountNumberEncrypted String
  bankAccountAge        BankAccountAge
  creditTier            CreditTier
  createdAt             DateTime        @default(now())

  application           Application     @relation(fields: [applicationIdRef], references: [id], onDelete: Cascade)
}

model Reference {
  id                    String       @id @default(uuid())
  applicationIdRef      String       @unique
  name                  String
  phone                 String
  relationship          String
  createdAt             DateTime     @default(now())

  application           Application  @relation(fields: [applicationIdRef], references: [id], onDelete: Cascade)
}

model LegalConsent {
  id                    String       @id @default(uuid())
  applicationIdRef      String       @unique
  creditAssessment      Boolean
  tcpaConsent           Boolean
  consentIpAddress      String?
  createdAt             DateTime     @default(now())

  application           Application  @relation(fields: [applicationIdRef], references: [id], onDelete: Cascade)
}

model StatusLog {
  id                    String            @id @default(uuid())
  applicationIdRef      String
  status                ApplicationStatus
  note                  String?
  createdAt             DateTime          @default(now())

  application           Application       @relation(fields: [applicationIdRef], references: [id], onDelete: Cascade)
}

enum BankVerificationStatus {
  PENDING
  COMPLETED
  FAILED
}

enum DocumentRequestStatus {
  REQUESTED
  UPLOADED
  APPROVED
  REJECTED
  EXPIRED
}

enum DocumentType {
  GOVERNMENT_ID
  PROOF_OF_ADDRESS
  INCOME_PROOF
  BANK_STATEMENT
  EMPLOYMENT_VERIFICATION
  OTHER
}

enum NotificationChannel {
  EMAIL
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationType {
  APPLICATION_SUBMITTED
  DOCUMENT_REQUEST
  STATUS_UPDATE
  BANK_VERIFICATION_REMINDER
  APPROVAL
  DECLINE
}

model BankVerification {
  id               String                 @id @default(uuid())
  applicationIdRef String                 @unique
  provider         String?
  status           BankVerificationStatus @default(PENDING)
  verifiedAt       DateTime?
  createdAt        DateTime               @default(now())

  application      Application            @relation(fields: [applicationIdRef], references: [id], onDelete: Cascade)
}

model DocumentRequest {
  id               String                @id @default(uuid())
  applicationIdRef String
  documentType     DocumentType
  message          String?
  token            String                @unique
  status           DocumentRequestStatus @default(REQUESTED)
  expiresAt        DateTime
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  application      Application           @relation(fields: [applicationIdRef], references: [id], onDelete: Cascade)
  document         Document?
}

model Document {
  id                String          @id @default(uuid())
  documentRequestId String          @unique
  fileName          String
  filePath          String
  mimeType          String
  uploadedAt        DateTime        @default(now())

  documentRequest   DocumentRequest @relation(fields: [documentRequestId], references: [id], onDelete: Cascade)
}

model Notification {
  id               String              @id @default(uuid())
  applicationIdRef String
  type             NotificationType
  channel          NotificationChannel
  recipient        String
  subject          String?
  message          String
  status           NotificationStatus  @default(PENDING)
  sentAt           DateTime?
  createdAt        DateTime            @default(now())

  application      Application         @relation(fields: [applicationIdRef], references: [id], onDelete: Cascade)
}

model ApplicationAgreement {
  id               String       @id @default(uuid())
  applicationIdRef String       @unique
  generatedAt      DateTime     @default(now())
  signedAt         DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  application      Application  @relation(fields: [applicationIdRef], references: [id], onDelete: Cascade)
}

enum AdminRole {
  STANDARD_AGENT
  MANAGER
}

model AdminUser {
  id             String      @id @default(uuid())
  name           String
  email          String      @unique
  passwordHash   String
  role           AdminRole   @default(STANDARD_AGENT)
  isActive       Boolean     @default(true)
  passwordChangeRequired Boolean @default(false)
  passwordResetToken String? @unique
  passwordResetExpiresAt DateTime?
  inviteSentAt   DateTime?
  lastLoginAt    DateTime?
  createdById    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  createdBy      AdminUser?  @relation("AdminUserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAdmins  AdminUser[] @relation("AdminUserCreatedBy")
}
